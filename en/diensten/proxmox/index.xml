<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Proxmox on MadeMy IT Solutions</title><link>https://mademy.nl/en/diensten/proxmox/</link><description>Recent content in Proxmox on MadeMy IT Solutions</description><generator>Hugo</generator><language>en</language><atom:link href="https://mademy.nl/en/diensten/proxmox/index.xml" rel="self" type="application/rss+xml"/><item><title>Proxmox Backup Server</title><link>https://mademy.nl/en/diensten/proxmox/proxmox-backup/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://mademy.nl/en/diensten/proxmox/proxmox-backup/</guid><description/></item><item><title>Proxmox Ceph</title><link>https://mademy.nl/en/diensten/proxmox/proxmox-ceph/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://mademy.nl/en/diensten/proxmox/proxmox-ceph/</guid><description/></item><item><title>Proxmox Datacenter Manager</title><link>https://mademy.nl/en/diensten/proxmox/proxmox-datacenter-manager/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://mademy.nl/en/diensten/proxmox/proxmox-datacenter-manager/</guid><description/></item><item><title>Proxmox Health Check</title><link>https://mademy.nl/en/diensten/proxmox/proxmox-health-check/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://mademy.nl/en/diensten/proxmox/proxmox-health-check/</guid><description>&lt;h2 id="what-is-ceph"&gt;What is Ceph?&lt;/h2&gt;
&lt;p&gt;Ceph is an open-source, software-defined storage platform that combines block, file and object storage in one scalable infrastructure. In combination with Proxmox VE, Ceph forms a powerful and cost-efficient storage solution for virtualization environments.&lt;/p&gt;
&lt;p&gt;By distributing storage directly across multiple nodes, no external SAN or NAS is needed. This makes Ceph ideal for modern hyperconverged infrastructures.&lt;/p&gt;
&lt;hr&gt;
&lt;h2 id="ceph-integrated-in-proxmox-ve"&gt;Ceph integrated in Proxmox VE&lt;/h2&gt;
&lt;p&gt;Proxmox VE includes native integration with Ceph, allowing storage to be managed directly from the Proxmox web interface.&lt;/p&gt;</description></item><item><title>Proxmox Support</title><link>https://mademy.nl/en/diensten/proxmox/proxmox-support/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://mademy.nl/en/diensten/proxmox/proxmox-support/</guid><description/></item><item><title>Proxmox VE</title><link>https://mademy.nl/en/diensten/proxmox/proxmox-ve/</link><pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate><guid>https://mademy.nl/en/diensten/proxmox/proxmox-ve/</guid><description/></item></channel></rss>